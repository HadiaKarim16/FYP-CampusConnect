# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Socket.io Configuration
VITE_SOCKET_URL=http://localhost:8000

# Environment
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true

# AI API Keys — copy this file to .env and fill in your key
# Only ONE needs to be filled. Leave others empty.

# Option A — Google Gemini (FREE — recommended)
# Get from: aistudio.google.com
VITE_GEMINI_API_KEY=

# Option B — OpenAI GPT
# Get from: platform.openai.com
VITE_OPENAI_API_KEY=

# Option C — Groq (FREE + Fastest)
# Get from: console.groq.com
VITE_GROQ_API_KEY=

# Which provider to use: 'gemini' | 'openai' | 'groq'
VITE_AI_PROVIDER=gemini